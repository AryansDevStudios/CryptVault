# Port for the Express server
PORT=3000

# The hashed version of your master password using bcrypt.
# You can generate this by running: node -e "require('bcrypt').hash('your_password', 10).then(console.log)"
MASTER_PASSWORD_HASH=$2b$10$wI5fGqF30R.0j1.E6T.2Z.xXk.0R0uJzXv/3c4OQ/j5.T.q3xG9F.

# Salt for deriving the AES encryption key from your master password using scrypt.
# You can generate a random 32-byte hex string by running: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_DERIVATION_SALT=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Secret used to sign session cookies. Generate a strong random string.
SESSION_SECRET=your_secure_session_secret_for_cookies
